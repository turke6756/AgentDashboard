{
  "name": "agent-dashboard",
  "version": "0.1.0",
  "description": "Workspace-centric Claude Agent Dashboard",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "npm run build:main && concurrently -k -n vite,electron \"npm run dev:renderer\" \"node -e \\\"setTimeout(()=>process.exit(),3000)\\\" && npm run start\"",
    "dev:renderer": "vite --port 5173",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "electron .",
    "rebuild": "node scripts/rebuild-native.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && npm run rebuild && npx electron-builder --config.npmRebuild=false"
  },
  "build": {
    "appId": "com.agentdashboard.app",
    "productName": "AgentDashboard",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts"
      },
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "icon": "assets/icon.ico",
    "win": {
      "target": "dir",
      "signAndEditExecutable": false,
      "icon": "assets/icon.ico"
    }
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@codemirror/autocomplete": "6.18.7",
    "@codemirror/commands": "6.5.0",
    "@codemirror/lang-markdown": "6.3.4",
    "@codemirror/lang-python": "6.1.7",
    "@codemirror/language": "6.10.8",
    "@codemirror/state": "6.4.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "6.26.4",
    "@datalayer/jupyter-react": "^2.0.7",
    "@jupyter/ydoc": "3.0.5",
    "@jupyterlab/services": "^7.5.6",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@rollup/rollup-win32-x64-msvc": "^4.59.0",
    "@tanstack/react-virtual": "^3.10.0",
    "@types/dompurify": "^3.0.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "anser": "2.1.1",
    "chokidar": "^5.0.0",
    "dompurify": "^3.3.3",
    "geotiff": "^3.0.5",
    "katex": "0.16.45",
    "leaflet": "^1.9.4",
    "lowlight": "3.3.0",
    "lucide-react": "^0.577.0",
    "node-pty": "^1.1.0",
    "proj4": "^2.20.8",
    "react-markdown": "9.0.3",
    "react-pdf": "^10.4.1",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "6.0.0",
    "shpjs": "^6.2.0",
    "sql.js": "^1.14.1",
    "uuid": "^13.0.0",
    "wkx": "^0.5.0",
    "ws": "^8.18.0",
    "xterm": "^5.3.0",
    "y-codemirror.next": "0.3.5",
    "y-websocket": "2.0.4",
    "yjs": "13.6.30",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.1",
    "@types/leaflet": "^1.9.21",
    "@types/proj4": "^2.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/shpjs": "^3.4.7",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "framer-motion": "^12.35.2",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "zustand": "^5.0.11"
  }
}
